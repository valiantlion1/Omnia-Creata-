{
  "background_removal": {
    "portrait": {
      "model": "rembg_u2net",
      "parameters": {
        "alpha_matting": true,
        "alpha_matting_foreground_threshold": 270,
        "alpha_matting_background_threshold": 10,
        "alpha_matting_erode_size": 10
      },
      "description": "Optimized for portrait photos"
    },
    "general": {
      "model": "rembg_u2net",
      "parameters": {
        "alpha_matting": false
      },
      "description": "Fast general background removal"
    }
  },
  "enhancement": {
    "auto": {
      "model": "auto_enhance",
      "parameters": {
        "brightness": 0.1,
        "contrast": 0.15,
        "saturation": 0.1,
        "sharpness": 0.05
      },
      "description": "Automatic enhancement"
    },
    "portrait": {
      "model": "portrait_enhance",
      "parameters": {
        "skin_smoothing": 0.3,
        "eye_enhancement": 0.2,
        "teeth_whitening": 0.1
      },
      "description": "Portrait-specific enhancements"
    }
  },
  "super_resolution": {
    "2x": {
      "model": "esrgan_2x",
      "parameters": {
        "scale": 2,
        "tile_size": 512,
        "tile_pad": 32
      },
      "description": "2x upscaling"
    },
    "4x": {
      "model": "esrgan_4x",
      "parameters": {
        "scale": 4,
        "tile_size": 256,
        "tile_pad": 16
      },
      "description": "4x upscaling (Premium)"
    }
  },
  "style_transfer": {
    "anime": {
      "model": "anime_gan",
      "parameters": {
        "style_strength": 0.8,
        "preserve_color": false
      },
      "description": "Convert to anime style"
    },
    "cartoon": {
      "model": "cartoon_gan",
      "parameters": {
        "style_strength": 0.7,
        "edge_enhancement": 0.3
      },
      "description": "Cartoon style conversion"
    }
  },
  "crop": {
    "smart": {
      "model": "yolo_crop",
      "parameters": {
        "confidence_threshold": 0.5,
        "crop_padding": 0.1,
        "aspect_ratio": "auto"
      },
      "description": "AI-powered smart cropping"
    },
    "face": {
      "model": "face_crop",
      "parameters": {
        "face_padding": 0.2,
        "min_face_size": 64,
        "max_faces": 1
      },
      "description": "Face-focused cropping"
    }
  }
}
