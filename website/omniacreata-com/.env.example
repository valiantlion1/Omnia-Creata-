# OmniaCreata public website env template
# Copy to .env.local for development or set these in the hosting provider for production.
# Do not commit real secrets.

# Public Studio URL — controls where "Open Studio" buttons go.
# Leave empty until Studio is live; buttons fall back to /products/omnia-creata-studio.
NEXT_PUBLIC_STUDIO_URL=

# Contact form delivery (server-only). If unset, the public contact path falls back to
# contact@omniacreata.com instead of submitting to a webhook.
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=
