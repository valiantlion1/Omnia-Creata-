{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Omnia Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "apps/studio/web",
      "port": 5173
    },
    {
      "name": "Omnia Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "apps/studio/backend",
      "port": 8000
    }
  ]
}
