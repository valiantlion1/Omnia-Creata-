*.hprof
gradle-temp/
*.jar

# System Files
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.idea/
.vscode/

# Build and Temp folders
temp/
backups/
archive/

# Node/Python specifics
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
