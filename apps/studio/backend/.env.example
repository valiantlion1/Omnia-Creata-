# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys (NEVER commit these to git)
OPENAI_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=
OPENROUTER_API_KEY=
STABILITY_API_KEY=
FAL_API_KEY=
RUNWARE_API_KEY=

# Model Configuration
HUGGINGFACE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
GEMINI_FREE_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PREMIUM_MODEL=gemini-2.5-pro
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_PREMIUM_MODEL=google/gemini-2.5-pro
OPENAI_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-5.4
# Optional targeted QA only; OpenAI image is not part of the normal public routing doctrine.
OPENAI_IMAGE_DRAFT_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Allowed chat providers: gemini, openrouter, openai, heuristic
CHAT_PRIMARY_PROVIDER=openrouter
CHAT_FALLBACK_PROVIDER=openai
PROTECTED_BETA_CHAT_PROVIDER=openrouter
PROTECTED_BETA_IMAGE_PROVIDER=runware
GEMINI_SERVICE_TIER=paid
OPENROUTER_SERVICE_TIER=paid
OPENAI_SERVICE_TIER=paid
GENERATION_PROVIDER_STRATEGY=managed-first
# Local-only safety switch: keep Fast text-to-image on zero-cost fallback lanes until
# you intentionally want billable Runware/Fal traffic during development.
DEVELOPMENT_FAST_ZERO_COST_MODE_ENABLED=true
CREATOR_MONTHLY_CREDITS=400
PRO_MONTHLY_CREDITS=1200
CREDIT_PACK_SMALL_CREDITS=200
CREDIT_PACK_LARGE_CREDITS=800
CREATOR_MONTHLY_PRICE_USD=12
PRO_MONTHLY_PRICE_USD=24
CREDIT_PACK_SMALL_PRICE_USD=8
CREDIT_PACK_LARGE_PRICE_USD=24
FREE_ACCOUNT_CHAT_MESSAGE_LIMIT=12
CREATOR_CHAT_MESSAGE_LIMIT=120
PRO_CHAT_MESSAGE_LIMIT=200
PUBLIC_PAID_PROVIDER_ECONOMICS_READY=false
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_BUILD=
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_NOTE=

STUDIO_OWNER_KEY=
STUDIO_OWNER_EMAIL=owner@omnia.local
STUDIO_OWNER_EMAILS=
STUDIO_ROOT_ADMIN_EMAILS=
STUDIO_OWNER_NAME=Omnia Owner

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/omniacreata
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio-assets
STATE_STORE_BACKEND=sqlite
STATE_STORE_PATH=
LEGACY_STATE_STORE_PATH=
STUDIO_RUNTIME_ROOT=
STUDIO_LOG_DIRECTORY=
POSTGRES_STATE_STORE_MIN_CONNECTIONS=2
POSTGRES_STATE_STORE_MAX_CONNECTIONS=10
POSTGRES_STATE_STORE_STATEMENT_TIMEOUT_MS=30000
ASSET_STORAGE_BACKEND=local

# Redis Configuration (optional in local development, required in staging/production)
REDIS_URL=
ENABLE_LIVE_PROVIDER_SMOKE=false

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=24h

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
MAX_REQUEST_HEADER_BYTES=16384
MAX_REQUEST_BODY_BYTES=8388608

# Paddle (for subscriptions and credit packs)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CHECKOUT_BASE_URL=
PADDLE_ENVIRONMENT=sandbox

# Monitoring
SENTRY_DSN=
OPENTELEMETRY_ENDPOINT=

# Generation Limits
MAX_CONCURRENT_GENERATIONS=3
MAX_QUEUE_SIZE=100
DEFAULT_TIMEOUT_SECONDS=300
GENERATION_RETRY_ATTEMPT_LIMIT=3
GENERATION_RETRY_DELAY_SECONDS=20
GENERATION_STALE_RUNNING_SECONDS=600
GENERATION_CLAIM_LEASE_SECONDS=60
GENERATION_MAINTENANCE_INTERVAL_SECONDS=10
GENERATION_RUNTIME_MODE=all
ENABLE_POLLINATIONS=true
ENABLE_DEMO_GENERATION_FALLBACK=false

# Cost Tracking
COST_PER_GENERATION_USD=0.01
COST_PER_UPSCALE_USD=0.005
