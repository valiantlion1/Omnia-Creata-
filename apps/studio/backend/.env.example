# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys (NEVER commit these to git)
OPENAI_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_TOKEN=
OPENROUTER_API_KEY=
STABILITY_API_KEY=
FAL_API_KEY=
RUNWARE_API_KEY=

# Model Configuration
HUGGINGFACE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PREMIUM_MODEL=gemini-2.5-pro
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_PREMIUM_MODEL=google/gemini-2.5-pro
OPENAI_MODEL=gpt-4o-mini
OPENAI_PREMIUM_MODEL=gpt-5.4
OPENAI_IMAGE_DRAFT_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Allowed chat providers: gemini, openrouter, openai, heuristic
CHAT_PRIMARY_PROVIDER=openrouter
CHAT_FALLBACK_PROVIDER=openai
GEMINI_SERVICE_TIER=free
OPENROUTER_SERVICE_TIER=paid
OPENAI_SERVICE_TIER=paid
GENERATION_PROVIDER_STRATEGY=free-first
PUBLIC_PAID_PROVIDER_ECONOMICS_READY=false
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_BUILD=
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_NOTE=

STUDIO_OWNER_KEY=
STUDIO_OWNER_EMAIL=owner@omnia.local
STUDIO_OWNER_EMAILS=
STUDIO_ROOT_ADMIN_EMAILS=
STUDIO_OWNER_NAME=Omnia Owner

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/omniacreata
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio-assets
STATE_STORE_BACKEND=sqlite
STATE_STORE_PATH=
LEGACY_STATE_STORE_PATH=
STUDIO_RUNTIME_ROOT=
STUDIO_LOG_DIRECTORY=
ASSET_STORAGE_BACKEND=local

# Redis Configuration (optional in local development, required in staging/production)
REDIS_URL=
ENABLE_LIVE_PROVIDER_SMOKE=false

# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=24h

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Stripe (for payments)
LEMONSQUEEZY_SECRET_KEY=
LEMONSQUEEZY_PUBLISHABLE_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=
OPENTELEMETRY_ENDPOINT=

# Generation Limits
MAX_CONCURRENT_GENERATIONS=3
MAX_QUEUE_SIZE=100
DEFAULT_TIMEOUT_SECONDS=300
GENERATION_RETRY_ATTEMPT_LIMIT=3
GENERATION_RETRY_DELAY_SECONDS=20
GENERATION_STALE_RUNNING_SECONDS=600
GENERATION_CLAIM_LEASE_SECONDS=60
GENERATION_MAINTENANCE_INTERVAL_SECONDS=10
GENERATION_RUNTIME_MODE=all
ENABLE_POLLINATIONS=true
ENABLE_DEMO_GENERATION_FALLBACK=false

# Cost Tracking
COST_PER_GENERATION_USD=0.01
COST_PER_UPSCALE_USD=0.005
