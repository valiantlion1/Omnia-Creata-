# Frontend Environment Variables
# Copy this file to .env and fill in your actual values
# Note: Only non-sensitive configuration should be here

# Backend API URL
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_AUTH_REDIRECT_BASE_URL=http://127.0.0.1:5173

# Never put provider API keys in Vite/browser env files.
# Browser env is public at build/runtime and should only hold non-sensitive client config.

# Development settings
VITE_ENVIRONMENT=development
VITE_DEBUG=true
