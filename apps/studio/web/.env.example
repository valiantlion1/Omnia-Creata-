# Frontend Environment Variables
# Copy this file to .env and fill in your actual values
# Note: Only non-sensitive configuration should be here

# Backend API URL
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_AUTH_REDIRECT_BASE_URL=http://127.0.0.1:5173

# HuggingFace Inference API (cloud) - optional
# If you want to use cloud generation via HF, set your token and optionally override model
VITE_HF_TOKEN=
VITE_HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Development settings
VITE_ENVIRONMENT=development
VITE_DEBUG=true
