# Copy to .env.platform before running canonical platform preflight or external verify.

ENVIRONMENT=staging
PUBLIC_WEB_BASE_URL=https://studio.omniacreata.com
PUBLIC_API_BASE_URL=https://studio-api.onrender.com
STAGING_VERIFY_BASE_URL=https://studio.omniacreata.com
STAGING_RUNTIME_ROOT=

FRONTEND_DEPLOY_PLATFORM=vercel
API_DEPLOY_PLATFORM=render
WORKER_DEPLOY_PLATFORM=render
REDIS_DEPLOY_PLATFORM=render
DATA_DEPLOY_PLATFORM=supabase
STORAGE_DEPLOY_PLATFORM=supabase
BILLING_BACKBONE_PROVIDER=paddle

STATE_STORE_BACKEND=postgres
ASSET_STORAGE_BACKEND=supabase
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
REDIS_URL=redis://red-xxxxxxxxxxxx:6379

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio-assets

JWT_SECRET=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
RUNWARE_API_KEY=
HUGGINGFACE_TOKEN=
OPENAI_IMAGE_DRAFT_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

CHAT_PRIMARY_PROVIDER=gemini
CHAT_FALLBACK_PROVIDER=openrouter
PROTECTED_BETA_CHAT_PROVIDER=gemini
PROTECTED_BETA_IMAGE_PROVIDER=runware
GEMINI_SERVICE_TIER=paid
OPENROUTER_SERVICE_TIER=paid
OPENAI_SERVICE_TIER=paid
GENERATION_PROVIDER_STRATEGY=managed-first
GENERATION_RUNTIME_MODE_WEB=web
GENERATION_RUNTIME_MODE_WORKER=worker

VITE_API_BASE_URL=https://studio-api.onrender.com
VITE_AUTH_REDIRECT_BASE_URL=https://studio.omniacreata.com

CREATOR_MONTHLY_CREDITS=400
PRO_MONTHLY_CREDITS=1200
CREDIT_PACK_SMALL_CREDITS=200
CREDIT_PACK_LARGE_CREDITS=800
CREATOR_MONTHLY_PRICE_USD=12
PRO_MONTHLY_PRICE_USD=24
CREDIT_PACK_SMALL_PRICE_USD=8
CREDIT_PACK_LARGE_PRICE_USD=24
FREE_ACCOUNT_CHAT_MESSAGE_LIMIT=12
CREATOR_CHAT_MESSAGE_LIMIT=120
PRO_CHAT_MESSAGE_LIMIT=200
PUBLIC_PAID_PROVIDER_ECONOMICS_READY=false
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_BUILD=
PUBLIC_PAID_PROVIDER_ECONOMICS_READY_NOTE=

PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
