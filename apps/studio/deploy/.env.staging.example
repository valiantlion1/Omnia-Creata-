# Copy to .env.staging before running docker compose.

ENVIRONMENT=staging
PUBLIC_WEB_BASE_URL=https://staging-studio.omniacreata.com
VITE_API_BASE_URL=/api
WEB_PORT=8080
STAGING_VERIFY_BASE_URL=http://127.0.0.1:8080
STAGING_RUNTIME_ROOT=

POSTGRES_DB=studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio-change-me
DATABASE_URL=postgresql://studio:studio-change-me@postgres:5432/studio
REDIS_URL=redis://redis:6379/0

STATE_STORE_BACKEND=postgres
GENERATION_RUNTIME_MODE_WEB=web
GENERATION_RUNTIME_MODE_WORKER=worker

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio-assets
ASSET_STORAGE_BACKEND=supabase

JWT_SECRET=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
RUNWARE_API_KEY=
HUGGINGFACE_TOKEN=
OPENAI_IMAGE_DRAFT_MODEL=gpt-image-1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

CHAT_PRIMARY_PROVIDER=openrouter
CHAT_FALLBACK_PROVIDER=openai
GEMINI_SERVICE_TIER=free
OPENROUTER_SERVICE_TIER=paid
OPENAI_SERVICE_TIER=paid
GENERATION_PROVIDER_STRATEGY=balanced

ENABLE_POLLINATIONS=true
ENABLE_LIVE_PROVIDER_SMOKE=false
