# Copy to .env.staging before running docker compose.

ENVIRONMENT=staging
PUBLIC_WEB_BASE_URL=https://staging-studio.omniacreata.com
VITE_API_BASE_URL=/api
WEB_PORT=8080

POSTGRES_DB=studio
POSTGRES_USER=studio
POSTGRES_PASSWORD=studio-change-me
DATABASE_URL=postgresql://studio:studio-change-me@postgres:5432/studio
REDIS_URL=redis://redis:6379/0

STATE_STORE_BACKEND=postgres
GENERATION_RUNTIME_MODE_WEB=web
GENERATION_RUNTIME_MODE_WORKER=worker

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=studio-assets
ASSET_STORAGE_BACKEND=supabase

JWT_SECRET=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
FAL_API_KEY=
RUNWARE_API_KEY=
HUGGINGFACE_TOKEN=

CHAT_PRIMARY_PROVIDER=gemini
CHAT_FALLBACK_PROVIDER=openrouter
GENERATION_PROVIDER_STRATEGY=balanced

ENABLE_POLLINATIONS=true
ENABLE_LIVE_PROVIDER_SMOKE=false
