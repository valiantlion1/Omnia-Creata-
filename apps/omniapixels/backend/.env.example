# Database
DATABASE_URL=sqlite:///./omniapixels.db

# Redis (optional, job queue)
REDIS_URL=redis://localhost:6379

# MinIO (optional, file storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=omniapixels

# API
ENV=development
APP_VERSION=1.0.0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8001"]

# JWT
JWT_SECRET_KEY=change-this-in-production

# Supabase (create a NEW project at supabase.com for OmniaPixels)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin emails (full access)
ADMIN_EMAILS=alierdincyigitaslan@gmail.com,ghostsofter12@gmail.com
