{
  "extends": "../packages/config/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "@main/*": [
        "./src/main/*"
      ],
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "electron.vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}
