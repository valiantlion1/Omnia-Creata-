# Omnia Watch web URLs
# Use localhost in development. Production should point to watch.omniacreata.com and the shared
# Omnia Creata account hub at account.omniacreata.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ACCOUNT_URL=https://account.omniacreata.com
NEXT_PUBLIC_MARKETING_URL=https://omniacreata.com

# Supabase public client credentials
# Required for live auth, Google OAuth, email/password, magic-link flows,
# session-aware dashboard reads, and connected web mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server credentials
# Required for live device pairing and scan ingestion routes.
SUPABASE_SERVICE_ROLE_KEY=

# Optional unless you validate JWTs outside the built-in Supabase clients.
SUPABASE_JWT_SECRET=

# Shared secret used to hash pairing codes and device bearer tokens before persistence.
DEVICE_CREDENTIAL_SECRET=

# Windows companion -> SaaS API base URL
AGENT_SYNC_API_BASE_URL=http://localhost:3000
AGENT_APPDATA_SUBDIR=OmniaWatch
