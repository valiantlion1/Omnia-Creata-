{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@prompt-vault/config": ["../packages/config/src/index.ts"],
      "@prompt-vault/i18n": ["../packages/i18n/src/index.ts"],
      "@prompt-vault/types": ["../packages/types/src/index.ts"],
      "@prompt-vault/validation": ["../packages/validation/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
