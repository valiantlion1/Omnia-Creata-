{
  "name": "prompt-vault",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @prompt-vault/web",
    "build": "npm run build --workspace @prompt-vault/web",
    "check": "npm run lint && npm run typecheck && npm run build",
    "lint": "npm run lint --workspace @prompt-vault/web",
    "typecheck": "npm run typecheck --workspace @prompt-vault/web",
    "android:add": "npm run cap:add:android --workspace @prompt-vault/web",
    "android:sync": "npm run cap:sync --workspace @prompt-vault/web",
    "android:open": "npm run cap:open --workspace @prompt-vault/web",
    "android:build:debug": "npm run android:build:debug --workspace @prompt-vault/web"
  }
}
